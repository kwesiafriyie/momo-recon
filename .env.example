# Server
PORT=8080

# PostgreSQL — e.g. postgres://user:pass@localhost:5432/momo_recon
DATABASE_URL=postgres://postgres:password@localhost:5432/momo_recon?sslmode=disable

# MTN MoMo Sandbox — get these from https://momodeveloper.mtn.com
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_SUBSCRIPTION_KEY=your_subscription_key_here
MOMO_API_USER_ID=your_api_user_id_here
MOMO_API_KEY=your_api_key_here
MOMO_TARGET_ENV=sandbox

# Must be a publicly reachable URL (use ngrok in dev)
MOMO_CALLBACK_URL=https://your-ngrok-url.ngrok.io/api/momo/callback
